engine-strict=true

# pnpm hoisting. Unlike npm's flat node_modules, pnpm keeps transitive deps
# isolated. vite-plugin-pwa (a transitive dep of @vite-pwa/sveltekit) needs two
# of its pieces visible at the root:
#   - its `virtual:pwa-register` module imports `workbox-window` by bare
#     specifier, so the build can't resolve it unless workbox is hoisted;
#   - src/app.d.ts references the `vite-plugin-pwa/*` type declarations.
# Without these, `pnpm build` and `pnpm check` both fail under pnpm's strict
# node_modules layout.
public-hoist-pattern[]=vite-plugin-pwa
public-hoist-pattern[]=workbox-*
